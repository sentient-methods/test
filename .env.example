# MakeItHappen Configuration
# Copy this to .env and fill in your values

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model assignments (defaults shown — override to customize)
# MODEL_ORCHESTRATOR=claude-opus-4-6
# MODEL_ENGINEER=claude-opus-4-6
# MODEL_CLASSIFIER=claude-haiku-4-5
# MODEL_TRANSLATOR=claude-sonnet-4-6
# MODEL_CEO_FILTER=claude-sonnet-4-6

# Server
# HOST=0.0.0.0
# PORT=8000

# Agent defaults
# MAX_AGENT_TURNS=25

# Project directory (where generated projects go)
# DEFAULT_PROJECT_DIR=.
